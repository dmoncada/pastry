FROM python:3.12-slim

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /app

COPY pyproject.toml uv.lock ./
COPY api/ ./api/
COPY cli/ ./cli/
COPY shared/ ./shared/

RUN uv sync --package pastry-api --no-dev --no-default-groups

ENV PATH="/app/.venv/bin:${PATH}"

EXPOSE 8080
CMD ["uvicorn", "pastry_api.main:app", "--host", "0.0.0.0", "--port", "8080"]
