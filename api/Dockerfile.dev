# Local dev image for the backend (and the table-init one-shot). Not the Lambda artifact.
FROM python:3.12-slim

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /app

# Copy the workspace so uv can resolve the pastry-shared path dependency.
COPY pyproject.toml uv.lock* ./
COPY shared/ ./shared/
COPY api/ ./api/

# Install just the backend member (and its workspace deps) into a venv.
RUN uv sync --package pastry-api --no-dev

ENV PATH="/app/.venv/bin:${PATH}"

EXPOSE 8080
CMD ["uvicorn", "pastry_api.main:app", "--host", "0.0.0.0", "--port", "8080"]
